{
  "name": "amux",
  "version": "0.1.0",
  "description": "Agent-native terminal multiplexer — like tmux, but with a JSON API for AI agents",
  "main": "dist/server.js",
  "bin": {
    "amux": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js start",
    "dev": "tsc --watch",
    "install:bin": "node scripts/install-bin.mjs",
    "uninstall:bin": "node scripts/uninstall-bin.mjs",
    "smoke": "npm run build && node scripts/smoke-test.mjs",
    "test": "npm run build"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "tmux",
    "agent",
    "pty",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dnakov/amux"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/node": "^25.5.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
